PLACES_PROVIDER=google
GOOGLE_PLACES_API_KEY=coloca_tu_api_key_aqui

# Google Places Nearby Search Pro tiene un free cap mensual. Esta app corta antes
# del tope real para dejar un margen de seguridad y evitar cobros accidentales.
GOOGLE_PLACES_FREE_CAP=5000
GOOGLE_PLACES_SAFETY_BUFFER=100
GOOGLE_PLACES_MONTHLY_LIMIT=4900
GOOGLE_PLACES_TYPE_GROUP_LIMIT=3
GOOGLE_PLACES_MAX_RESULTS=60

# Contador persistente recomendado para produccion en Render.
# Crea una base Redis gratis en Upstash y pega estos valores.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Fallback local para desarrollo cuando no hay Upstash. Esta ruta esta ignorada por git.
GOOGLE_PLACES_USAGE_FILE=.quota/google-places-usage.json
